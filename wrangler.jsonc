{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "book",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-13",
  "assets": {
    "directory": "public",
    "not_found_handling": "404-page"
  },
